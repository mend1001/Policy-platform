{
  "info": {
    "name": "Polizas Platform — API REST",
    "description": "Colección completa para la API de gestión de pólizas de arrendamiento.\n\nRequisito: importar también el entorno 'Polizas Platform — Local' para que {{base_url}} y {{api_key}} funcionen.\n\nFlujo recomendado:\n1. Ejecutar R01 (captura policy_id, beneficiary_id, holder_id automáticamente)\n2. Ejecutar R08 (captura risk_id automáticamente)\n3. Resto de requests en orden\n\nNota R12: requiere ejecutar R14-setup primero (cancelar póliza antes de renovar).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "policy_id", "value": "" },
    { "key": "risk_id", "value": "" },
    { "key": "beneficiary_id", "value": "" },
    { "key": "holder_id", "value": "" }
  ],
  "item": [
    {
      "name": "Pólizas",
      "item": [
        {
          "name": "Listar",
          "item": [
            {
              "name": "R01 — Listar todas las pólizas (captura policy_id)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tiene httpStatus', () => pm.expect(pm.response.json()).to.have.property('httpStatus'));",
                      "pm.test('Tiene timestamp', () => pm.expect(pm.response.json()).to.have.property('timestamp'));",
                      "pm.test('Tiene message', () => pm.expect(pm.response.json()).to.have.property('message'));",
                      "pm.test('Tiene data', () => pm.expect(pm.response.json()).to.have.property('data'));",
                      "pm.test('data.content es array', () => pm.expect(pm.response.json().data.content).to.be.an('array'));",
                      "pm.test('Al menos una poliza', () => pm.expect(pm.response.json().data.totalElements).to.be.greaterThan(0));",
                      "pm.test('Captura policy_id', () => {",
                      "  const json = pm.response.json();",
                      "  if (json.data.content.length > 0) {",
                      "    const p = json.data.content[0];",
                      "    pm.collectionVariables.set('policy_id', p.id);",
                      "    pm.collectionVariables.set('beneficiary_id', p.beneficiaryId);",
                      "    pm.collectionVariables.set('holder_id', p.holderId);",
                      "  }",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"]
                }
              }
            },
            {
              "name": "R02 — Listar paginado (page=0, size=2)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tiene httpStatus', () => pm.expect(pm.response.json()).to.have.property('httpStatus'));",
                      "pm.test('data.content es array', () => pm.expect(pm.response.json().data.content).to.be.an('array'));",
                      "pm.test('Tiene totalElements', () => pm.expect(pm.response.json().data).to.have.property('totalElements'));",
                      "pm.test('Tiene totalPages', () => pm.expect(pm.response.json().data).to.have.property('totalPages'));",
                      "pm.test('Size respeta parametro', () => pm.expect(pm.response.json().data.content.length).to.be.at.most(2));"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas?page=0&size=2",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"],
                  "query": [
                    { "key": "page", "value": "0" },
                    { "key": "size", "value": "2" }
                  ]
                }
              }
            },
            {
              "name": "R03 — Listar pólizas tipo INDIVIDUAL",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Tiene httpStatus', () => pm.expect(pm.response.json()).to.have.property('httpStatus'));",
                      "pm.test('Todas son INDIVIDUAL', () => {",
                      "  pm.response.json().data.content.forEach(p => pm.expect(p.type).to.equal('INDIVIDUAL'));",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas?tipo=INDIVIDUAL",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"],
                  "query": [{ "key": "tipo", "value": "INDIVIDUAL" }]
                }
              }
            },
            {
              "name": "R04 — Listar pólizas tipo COLECTIVA",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Todas son COLECTIVA', () => {",
                      "  pm.response.json().data.content.forEach(p => pm.expect(p.type).to.equal('COLECTIVA'));",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas?tipo=COLECTIVA",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"],
                  "query": [{ "key": "tipo", "value": "COLECTIVA" }]
                }
              }
            },
            {
              "name": "R05 — Listar pólizas estado ACTIVA",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Todas están ACTIVA', () => {",
                      "  pm.response.json().data.content.forEach(p => pm.expect(p.state).to.equal('ACTIVA'));",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas?estado=ACTIVA",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"],
                  "query": [{ "key": "estado", "value": "ACTIVA" }]
                }
              }
            },
            {
              "name": "R06 — Listar COLECTIVA + ACTIVA (filtro combinado)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Todas son COLECTIVA y ACTIVA', () => {",
                      "  pm.response.json().data.content.forEach(p => {",
                      "    pm.expect(p.type).to.equal('COLECTIVA');",
                      "    pm.expect(p.state).to.equal('ACTIVA');",
                      "  });",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas?tipo=COLECTIVA&estado=ACTIVA",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"],
                  "query": [
                    { "key": "tipo", "value": "COLECTIVA" },
                    { "key": "estado", "value": "ACTIVA" }
                  ]
                }
              }
            }
          ]
        },
        {
