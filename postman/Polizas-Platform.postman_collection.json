        {
          "name": "Listar",
          "item": [
            {
              "name": "R01 — Listar todas las pólizas",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Respuesta es array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                      "pm.test('Al menos una póliza', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas",
                  "host": ["{{base_url}}"],
                  "path": ["polizas"]
                }
