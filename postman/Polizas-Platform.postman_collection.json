        {
          "name": "Riesgos de Póliza",
          "item": [
            {
              "name": "R11 — Listar riesgos de póliza COLECTIVA (requiere R01, captura risk_id)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const collId = pm.collectionVariables.get('policy_id');",
                      "if (!collId) { console.warn('policy_id no seteado — ejecutar R01 primero'); }"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200 o 404', () => {",
                      "  pm.expect([200, 404]).to.include(pm.response.code);",
                      "});",
                      "pm.test('Tiene httpStatus', () => pm.expect(pm.response.json()).to.have.property('httpStatus'));",
                      "pm.test('Captura risk_id si hay riesgos', () => {",
                      "  const json = pm.response.json();",
                      "  if (json.httpStatus === 200 && json.data && json.data.content && json.data.content.length > 0) {",
                      "    pm.collectionVariables.set('risk_id', json.data.content[0].id);",
                      "  }",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "x-api-key", "value": "{{api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/polizas/{{policy_id}}/risks",
                  "host": ["{{base_url}}"],
                  "path": ["polizas", "{{policy_id}}", "risks"]
                }
              }
